<UserControl x:Class="CourseProgect_Planeta35.Controls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.2">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.2,0.2"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 🧊 UI -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0 0 0 16">
                <TextBlock Text="Отчёты"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Формирование аналитики по имуществу и инвентаризации"
                           Foreground="#BFCBC2"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <!-- FILTER CARD -->
            <Border Grid.Row="1"
                    Background="#1E2421"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#2F3B33"
                    BorderThickness="1"
                    Margin="0 0 0 14">

                <StackPanel>

                    <WrapPanel Margin="0 0 0 10">

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Тип отчёта" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbReportType" Width="260"/>
                        </StackPanel>

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Категория" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbCategory" Width="200"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Подразделение" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbDepartment" Width="200"/>
                        </StackPanel>

                    </WrapPanel>

                    <WrapPanel>

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Статус" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbStatus" Width="200"/>
                        </StackPanel>

                        <Button Content="Обновить"
                                Width="120"
                                Margin="0 18 8 0"
                                Background="#8B9B4C"
                                Foreground="White"
                                BorderThickness="0"/>

                        <Button Content="Сброс"
                                Width="100"
                                Margin="0 18 8 0"
                                Background="#2A322D"
                                Foreground="White"
                                BorderThickness="0"/>

                        <Button Content="PDF"
                                Width="100"
                                Margin="0 18 8 0"
                                Background="#2A322D"
                                Foreground="White"
                                BorderThickness="0"/>

                        <Button Content="XLSX"
                                Width="100"
                                Margin="0 18 0 0"
                                Background="#2A322D"
                                Foreground="White"
                                BorderThickness="0"/>

                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- DATA GRID CARD -->
            <Border Grid.Row="2"
                    Background="#1E2421"
                    CornerRadius="14"
                    Padding="10"
                    BorderBrush="#2F3B33"
                    BorderThickness="1">

                <DataGrid x:Name="DataGridPreview"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="White"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowBackground="#232B26"
                          AlternatingRowBackground="#1E2421"
                          BorderThickness="0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Asset.Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Asset.Category.Name}" Width="*"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding Asset.Department.Name}" Width="*"/>
                        <DataGridTextColumn Header="Ответственный" Binding="{Binding Asset.Responsible.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Серийный №" Binding="{Binding Asset.InventoryNumber}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Asset.Status}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- FOOTER -->
            <TextBlock Grid.Row="3"
                       Text="{Binding PreviewInfo}"
                       Foreground="#BFCBC2"
                       Margin="0 10 0 0"/>

        </Grid>
    </Grid>
</UserControl>