<UserControl x:Class="CourseProgect_Planeta35.Controls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A322D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3E5C4C"/>
                            </Trigger>

                            <!-- pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#8B9B4C"/>
                            </Trigger>

                            <!-- disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"/>

                            <Grid Margin="10,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected -->
                                <ContentPresenter Grid.Column="0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"/>

                                <!-- Arrow -->
                                <ToggleButton Grid.Column="1"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand">

                                    <TextBlock Text="▼"
                                       FontSize="10"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                </ToggleButton>

                            </Grid>

                            <!-- Dropdown -->
                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           PopupAnimation="Fade">

                                <Border Background="#1C2621"
                                BorderBrush="#3E5C4C"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,5,0,0">

                                    <ScrollViewer>

                                        <ItemsPresenter/>

                                    </ScrollViewer>

                                </Border>

                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ITEMS -->
        <Style TargetType="ComboBoxItem">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBoxItem">

                        <Border x:Name="Bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Margin="4">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#24352C"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#3E5C4C"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.2">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.2,0.2"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 🧊 UI -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0 0 0 16">
                <TextBlock Text="Отчёты"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Формирование аналитики по имуществу и инвентаризации"
                           Foreground="#BFCBC2"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <!-- FILTER CARD -->
            <Border Grid.Row="1"
                    Background="#1E2421"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#2F3B33"
                    BorderThickness="1"
                    Margin="0 0 0 14">

                <StackPanel>

                    <WrapPanel Margin="0 0 0 10">

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Тип отчёта" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbReportType"
                                      Width="260"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="CbReportType_SelectionChanged">
                                <ComboBoxItem Content="Общий отчет по имуществу"/>
                                <ComboBoxItem Content="Отчет по результатам инвентаризации"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Категория" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbCategory"
                                      Width="200"
                                      Style="{StaticResource DarkComboBox}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Подразделение" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbDepartment" Width="200" Style="{StaticResource DarkComboBox}" DisplayMemberPath="Name"/>
                        </StackPanel>

                    </WrapPanel>

                    <WrapPanel>

                        <StackPanel Margin="0 0 20 0">
                            <TextBlock Text="Статус" Foreground="#BFCBC2"/>
                            <ComboBox x:Name="CbStatus"
                                      Width="200"
                                      Style="{StaticResource DarkComboBox}">
                                <ComboBoxItem Content="Все"/>
                                <ComboBoxItem Content="В эксплуатации"/>
                                <ComboBoxItem Content="На обслуживании"/>
                                <ComboBoxItem Content="Списано"/>
                                <ComboBoxItem Content="Отсутствует"/>
                            </ComboBox>
                        </StackPanel>

                        <Button Content="Обновить"
                                Width="120"
                                Margin="0 15 8 10"
                                Click="BtnRefresh_Click"
                                Background="#3E5C4C"
                                Foreground="White"
                                Style="{StaticResource ActionButtonStyle}"
                                BorderThickness="0"/>

                        <Button Content="Сброс"
                                Width="100"
                                Margin="0 15 8 10"
                                Click="BtnResetFilters_Click"
                                Background="#2A322D"
                                Foreground="White"
                                Style="{StaticResource ActionButtonStyle}"
                                BorderThickness="0"/>

                        <Button Content="PDF"
                                Width="100"
                                Margin="0 15 8 10"                                
                                Click="BtnExportPdf_Click"
                                Background="#2A322D"
                                Foreground="White"
                                Style="{StaticResource ActionButtonStyle}"
                                BorderThickness="0"/>

                        <Button Content="XLSX"
                                Width="100"
                                Margin="0 15 8 10"
                                Click="BtnExportXlsx_Click"
                                Background="#2A322D"
                                Foreground="White"
                                Style="{StaticResource ActionButtonStyle}"
                                BorderThickness="0"/>

                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- DATA GRID CARD -->
            <Border Grid.Row="2"
                    Background="#1E2421"
                    CornerRadius="14"
                    Padding="10"
                    BorderBrush="#2F3B33"
                    BorderThickness="1">

                <DataGrid x:Name="DataGridPreview"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="#2F3B33"
                          Foreground="White"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowBackground="#232B26"
                          AlternatingRowBackground="#1E2421"
                          BorderThickness="0">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#EAEAEA"/>
                            <Setter Property="Foreground" Value="#2F3B33"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Asset.Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Asset.Category.Name}" Width="*"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding Asset.Department.Name}" Width="*"/>
                        <DataGridTextColumn Header="Ответственный" Binding="{Binding Asset.Responsible.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Серийный №" Binding="{Binding Asset.InventoryNumber}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Asset.Status}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- FOOTER -->
            <TextBlock Grid.Row="3"
                       Text="{Binding PreviewInfo}"
                       Foreground="#BFCBC2"
                       Margin="0 10 0 0"/>

        </Grid>
    </Grid>
</UserControl>