<UserControl x:Class="CourseProgect_Planeta35.Pages.CategoriesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#151A17">

    <UserControl.Resources>

        <!-- SHADOWS -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.25"
                          Color="#000000"/>

        <DropShadowEffect x:Key="CardShadowHover"
                          BlurRadius="28"
                          ShadowDepth="6"
                          Opacity="0.35"
                          Color="#000000"/>

        <!-- BUTTON -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#3E5C4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A7A65"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2F3A33"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CATEGORY CARD (НОРМАЛЬНЫЙ ВАРИАНТ) -->
        <Style x:Key="CategoryCardStyle" TargetType="Border">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="150"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Background" Value="#1E2320"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#2F3B33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.25"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#232B26"/>
                    <Setter Property="BorderBrush" Value="#8B9B4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- BACKGROUND -->
    <Grid>

        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#151A17" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.12">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.3,0.3"
                                         GradientOrigin="0.2,0.2"
                                         RadiusX="0.8"
                                         RadiusY="0.8">
                        <GradientStop Color="#3E5C4C" Offset="0"/>
                        <GradientStop Color="#151A17" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.10">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.8,0.2"
                                         GradientOrigin="0.9,0.1"
                                         RadiusX="0.8"
                                         RadiusY="0.8">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#151A17" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

        </Grid>

        <!-- CONTENT -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Background="#1E2320"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#2F3B33"
                    BorderThickness="1"
                    Margin="0 0 0 20">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Категории имущества"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock x:Name="CountText"
                                   Margin="0 4 0 0"
                                   Foreground="#BFCBC2"
                                   Text="0 категорий"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="200"
                            Height="40"
                            Click="AddCategory_Click"
                            Style="{StaticResource MainButton}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋"
                                       FontSize="18"
                                       Margin="0,-3,6,0"/>
                            <TextBlock Text="Добавить"/>
                        </StackPanel>

                    </Button>

                </Grid>

            </Border>

            <!-- CARDS -->
            <ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="CategoryPanel"/>

            </ScrollViewer>

        </Grid>

    </Grid>

</UserControl>