<Window x:Class="CourseProgect_Planeta35.Controls.AddAssetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить объект"
        Height="730" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
             Background="{TemplateBinding Background}"
             BorderBrush="{TemplateBinding BorderBrush}"
             BorderThickness="{TemplateBinding BorderThickness}"
             CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                     Property="BorderBrush"
                     Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                     Property="BorderBrush"
                     Value="#8B9B4C"/>
                                <Setter TargetName="border"
                     Property="Background"
                     Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"/>

                            <Grid Margin="10,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected -->
                                <ContentPresenter Grid.Column="0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                                <!-- Arrow -->
                                <ToggleButton Grid.Column="1"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand">

                                    <TextBlock Text="▼"
                                       FontSize="10"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                </ToggleButton>

                            </Grid>

                            <!-- Dropdown -->
                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           PopupAnimation="Fade">

                                <Border Background="#1C2621"
                                BorderBrush="#3E5C4C"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,5,0,0">

                                    <ScrollViewer>

                                        <ItemsPresenter/>

                                    </ScrollViewer>

                                </Border>

                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ITEMS -->
        <Style TargetType="ComboBoxItem">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBoxItem">

                        <Border x:Name="Bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Margin="4">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#24352C"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#3E5C4C"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24352C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5C4C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки отмены -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="Foreground" Value="#3C2F1F"/>
        </Style>

    </Window.Resources>

    <Border CornerRadius="16"
            Background="#2B3A31"
            Padding="20"
            Margin="10"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Добавить объект" FontSize="24" FontWeight="Bold"
                           Margin="0,0,0,20" Foreground="White"/>

                <!-- Название -->
                <TextBlock Text="Название" Foreground="White"/>
                <TextBox x:Name="NameBox"/>

                <!-- Описание -->
                <TextBlock Text="Описание" Foreground="White"/>
                <TextBox x:Name="DescriptionBox"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Категория -->
                <TextBlock Text="Категория" Foreground="White"/>
                <ComboBox x:Name="CategoryBox"/>

                <!-- Статус -->
                <TextBlock Text="Статус" Foreground="White"/>
                <ComboBox x:Name="StatusBox">
                    <ComboBoxItem Content="В эксплуатации"/>
                    <ComboBoxItem Content="На обслуживании"/>
                    <ComboBoxItem Content="Списано"/>
                    <ComboBoxItem Content="Отсутствует"/>
                </ComboBox>

                <!-- Серийный номер -->
                <TextBlock Text="Серийный номер" Foreground="White"/>
                <TextBox x:Name="SerialBox"/>

                <!-- Дата покупки -->
                <TextBlock Text="Дата покупки" Foreground="White"/>
                <DatePicker x:Name="PurchaseDateBox"
                            Height="30"
                            Margin="0,0,0,10"/>

                <!-- Стоимость -->
                <TextBlock Text="Стоимость" Foreground="White"/>
                <TextBox x:Name="CostBox"/>

                <!-- Локация / отдел -->
                <TextBlock Text="Местоположение (Отдел)" Foreground="White"/>
                <ComboBox x:Name="LocationBox"/>

                <!-- Изображение -->
                <TextBlock Text="Изображение" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="ImagePathBox" Width="230"/>
                    <Button Content="Обзор" Width="60" Margin="5,0,0,0"
                            Style="{StaticResource MainButton}"
                            Click="BrowseImage_Click"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Отмена" Width="80" Style="{StaticResource CancelButton}"
                            Click="Cancel_Click"/>
                    <Button Content="Добавить" Width="80" Style="{StaticResource MainButton}"
                            Click="Add_Click" Background="#3E5C4C"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>

</Window>
