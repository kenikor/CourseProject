<UserControl x:Class="CourseProgect_Planeta35.Pages.UserAddControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F1E9">

    <UserControl.Resources>
        <!-- Стили оставляем как есть -->
        <Style x:Key="RoleBadge" TargetType="Border">
            <Setter Property="Padding" Value="6 2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="#8B9B4C"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24352C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5C4C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F8C45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="DropShadow" Color="#000000" ShadowDepth="4" BlurRadius="12" Opacity="0.25"/>

        <!-- Карточка пользователя -->
        <DataTemplate x:Key="UserCardTemplate">

            <Border Width="920"
            Margin="0 0 0 14"
            CornerRadius="20"
            BorderThickness="1"
            BorderBrush="#2F3B33"
            Background="#1E2320"
            Padding="18"
            HorizontalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.25"/>
                </Border.Effect>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel Orientation="Horizontal">

                        <!-- AVATAR -->
                        <Border Width="56"
                        Height="56"
                        CornerRadius="28"
                        Background="#273029"
                        VerticalAlignment="Top">

                            <Grid>

                                <Ellipse Fill="#3E5C4C"/>

                                <TextBlock Text="{Binding FullName[0]}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                        <!-- INFO -->
                        <StackPanel Margin="16 0 0 0">

                            <!-- NAME -->
                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="{Binding FullName}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                                <!-- ROLE -->
                                <Border Margin="10 0 0 0"
                                Padding="10 4"
                                CornerRadius="8"
                                Background="#3E5C4C">

                                    <TextBlock Text="{Binding Role.Name}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>

                                </Border>

                            </StackPanel>

                            <!-- EMAIL -->
                            <TextBlock Text="{Binding Username}"
                               Margin="0 10 0 0"
                               Foreground="#C7D2CB"
                               FontSize="13"/>

                            <!-- DEPARTMENT -->
                            <StackPanel Orientation="Horizontal"
                                Margin="0 6 0 0">

                                <Ellipse Width="8"
                                 Height="8"
                                 Fill="#8B9B4C"
                                 VerticalAlignment="Center"/>

                                <TextBlock Text="{Binding Department.Name}"
                                   Margin="8 0 0 0"
                                   Foreground="#BFCBC2"
                                   FontSize="13"/>

                            </StackPanel>

                        </StackPanel>

                    </StackPanel>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">

                        <!-- EDIT -->
                        <Button Width="42"
                        Height="42"
                        Margin="0 0 8 0"
                        Background="#273029"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="EditUser_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12">

                                        <TextBlock Text="✎"
                                           FontSize="16"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg"
                                            Property="Background"
                                            Value="#3E5C4C"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                        <!-- DELETE -->
                        <Button Width="42"
                        Height="42"
                        Background="#2B1F1F"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="DeleteUser_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12">

                                        <TextBlock Text="🗑"
                                           FontSize="16"
                                           Foreground="#FF7B7B"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg"
                                            Property="Background"
                                            Value="#4A2323"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </StackPanel>

                </Grid>

            </Border>

        </DataTemplate>
        
    </UserControl.Resources>

    <Grid>

        <Grid>

            <!-- БАЗА (тёмно-зелёная) -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- МЯГКОЕ СВЕТОВОЕ ПЯТНО -->
            <Rectangle Opacity="0.25">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="BgBrush1"
                                 Center="0.3,0.3"
                                 GradientOrigin="0.2,0.2"
                                 RadiusX="0.9"
                                 RadiusY="0.9">
                        <GradientStop Color="#3E5C4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- АКЦЕНТНОЕ ОЛИВКОВОЕ ПЯТНО -->
            <Rectangle Opacity="0.15">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="BgBrush2"
                                 Center="0.8,0.2"
                                 GradientOrigin="0.9,0.1"
                                 RadiusX="0.8"
                                 RadiusY="0.8">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

        </Grid>

        <!-- 🧊 ОСНОВНОЙ UI -->
        <Grid Margin="16" Cursor="Hand">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <!-- HEADER -->
            <Border Grid.Row="0"
        Background="#1E2320"
        CornerRadius="18"
        Padding="20"
        BorderBrush="#2F3B33"
        BorderThickness="1"
        Margin="0 0 0 20">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel>

                        <TextBlock Text="Пользователи"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"/>

                        <TextBlock Text="Управление сотрудниками системы"
                       Margin="0 4 0 0"
                       Foreground="#BFCBC2"
                       FontSize="13"/>

                    </StackPanel>

                    <!-- RIGHT -->
                    <Button Grid.Column="1"
                Width="200"
                Height="42"
                Click="AddUser_Click"
                Background="#42604F"
                BorderThickness="0"
                Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">

                                    <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                        <TextBlock Text="+"
                                       FontSize="18"
                                       Foreground="White"
                                       Margin="0,-2,8,0"/>

                                        <TextBlock Text="Добавить"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>

                                    </StackPanel>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg"
                                    Property="Background"
                                    Value="#567564"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bg"
                                    Property="Background"
                                    Value="#31473A"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Button.Template>

                    </Button>

                </Grid>

            </Border>

            <!-- Список -->
            <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                <ListBox x:Name="UsersList"
                     ItemTemplate="{StaticResource UserCardTemplate}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"/>
            </ScrollViewer>

            <!-- Popup -->
            <Border x:Name="AddPanel"
                Background="White"
                CornerRadius="14"
                Padding="24"
                BorderBrush="#DDD"
                BorderThickness="1"
                Visibility="Collapsed"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0 80 0 0"
                Panel.ZIndex="999"
                Effect="{DynamicResource DropShadow}">

                <StackPanel>
                    <TextBlock Text="Имя" Margin="0 0 0 4"/>
                    <TextBox x:Name="NameBox" Margin="0 0 0 12"/>

                    <TextBlock Text="Email" Margin="0 0 0 4"/>
                    <TextBox x:Name="EmailBox" Margin="0 0 0 12"/>

                    <TextBlock Text="Роль" Margin="0 0 0 4"/>
                    <ComboBox x:Name="RoleBox" Margin="0 0 0 12"/>

                    <TextBlock Text="Отдел" Margin="0 0 0 4"/>
                    <ComboBox x:Name="DepartmentBox" Margin="0 0 0 12"/>

                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 12 0 0">

                        <Button Content="Сохранить"
                            Width="130"
                            Margin="0 0 8 0"
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveNewUser_Click"/>

                        <Button Content="Отмена"
                            Width="110"
                            Style="{StaticResource SecondaryButton}"
                            Click="CancelAdd_Click"/>
                    </StackPanel>
                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</UserControl>
