<UserControl x:Class="CourseProgect_Planeta35.Controls.InventoryCheckControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CourseProgect_Planeta35.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Height="Auto" Width="Auto">

    <UserControl.Resources>

        <!-- 🔧 конвертеры -->
        <local:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>

    </UserControl.Resources>

    <Grid>

        <!-- 🌑 фон -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A1F1C" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.25">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.3,0.3"
                                     GradientOrigin="0.2,0.2"
                                     RadiusX="0.9"
                                     RadiusY="0.9">
                    <GradientStop Color="#3E5C4C" Offset="0"/>
                    <GradientStop Color="#1A1F1C" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.15">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.8,0.2"
                                     GradientOrigin="0.9,0.1"
                                     RadiusX="0.8"
                                     RadiusY="0.8">
                    <GradientStop Color="#8B9B4C" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 🧊 UI -->
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="25 20 0 10">
                <TextBlock Text="Инвентаризация"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Проверьте наличие и состояние объектов учёта"
                           FontSize="14"
                           Foreground="#CFCFCF"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <!-- PROGRESS -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Right"
                        Margin="0 10 25 10">

                <TextBlock x:Name="ProgressPercentText"
                           Text="0%"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Right"/>

                <TextBlock Text="Завершено"
                           FontSize="12"
                           Foreground="#B5C7BA"
                           HorizontalAlignment="Right"
                           Margin="0 -4 0 6"/>

                <Border Width="140" Height="6"
                        CornerRadius="3"
                        Background="#2F3B33">

                    <Border x:Name="ProgressBarFill"
                            Background="#8B9B4C"
                            CornerRadius="3"
                            Width="0"/>
                </Border>

            </StackPanel>

            <!-- CONTENT -->
            <Border Grid.Row="2"
                    Margin="25"
                    Padding="20"
                    Background="#1E2421"
                    CornerRadius="12"
                    BorderBrush="#2F3B33"
                    BorderThickness="1">

                <DockPanel>

                    <!-- SEARCH -->
                    <StackPanel DockPanel.Dock="Top">

                        <Border Background="#2A322D"
                                Height="40"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0 0 0 15">

                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="14"
                                     TextChanged="SearchBox_TextChanged"
                                     VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="FoundCountText"
                                   Text="Найдено объектов: 0"
                                   Foreground="#BFCBC2"
                                   FontSize="14"
                                   Margin="5 0 0 10"/>
                    </StackPanel>

                    <!-- LIST -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <ItemsControl x:Name="ItemsList">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Click="Item_Click">

                                        <!-- CARD -->
                                        <Border Margin="0 6"
                                                Width="620"
                                                Padding="14"
                                                Background="#232B26"
                                                CornerRadius="12"
                                                BorderBrush="#2F3B33"
                                                BorderThickness="1">

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </Setter.Value>
                                                    </Setter>

                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#27322B"/>
                                                            <Setter Property="BorderBrush" Value="#8B9B4C"/>
                                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- IMAGE -->
                                                <Border Width="64"
                                                        Height="64"
                                                        CornerRadius="10"
                                                        ClipToBounds="True">

                                                    <Image Source="{Binding Asset.ImagePath}"
                                                           Stretch="UniformToFill"/>
                                                </Border>

                                                <!-- INFO -->
                                                <StackPanel Grid.Column="1"
                                                            Margin="12 0">

                                                    <TextBlock Text="{Binding Asset.Name}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0 6 0 0">

                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 Fill="#8B9B4C"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0 0 6 0"/>

                                                        <TextBlock Text="{Binding Asset.Category.Name}"
                                                                   FontSize="12"
                                                                   Foreground="#BFCBC2"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Asset.SerialNumber, StringFormat=SN: {0}}"
                                                               FontSize="12"
                                                               Foreground="#9AA59F"
                                                               Margin="0 4 0 0"/>
                                                </StackPanel>

                                                <!-- STATUS -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right">

                                                    <Border Padding="8 4"
                                                            CornerRadius="8"
                                                            Background="{Binding Asset.IsChecked, Converter={StaticResource BoolToColorConverter}}">

                                                        <TextBlock Text="{Binding Asset.IsChecked, Converter={StaticResource BoolToTextConverter}}"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- hidden checkbox -->
                                                    <CheckBox IsChecked="{Binding Asset.IsChecked, Mode=TwoWay}"
                                                              Checked="CheckBox_CheckedUnchecked"
                                                              Unchecked="CheckBox_CheckedUnchecked"
                                                              Opacity="0"
                                                              Width="0"
                                                              Height="0"/>

                                                </StackPanel>

                                            </Grid>

                                        </Border>

                                    </Button>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </DockPanel>

            </Border>

        </Grid>

    </Grid>
</UserControl>