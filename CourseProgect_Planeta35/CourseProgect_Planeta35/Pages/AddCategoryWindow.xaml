<Window x:Class="CourseProgect_Planeta35.Pages.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить категорию"
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Общий стиль TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
             Background="{TemplateBinding Background}"
             BorderBrush="{TemplateBinding BorderBrush}"
             BorderThickness="{TemplateBinding BorderThickness}"
             CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                     Property="BorderBrush"
                     Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                     Property="BorderBrush"
                     Value="#8B9B4C"/>
                                <Setter TargetName="border"
                     Property="Background"
                     Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24352C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5C4C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки отмены -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="Foreground" Value="#3C2F1F"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#2B3A31"
            Padding="20"
            Margin="10"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel>
            <TextBlock Text="Добавить категорию" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="White"/>

            <TextBlock Text="Название категории" Foreground="White"/>
            <TextBox x:Name="NameBox"/>

            <TextBlock Text="Описание" Foreground="White"/>
            <TextBox x:Name="DescriptionBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Цвет категории" Foreground="White" Margin="10,20,10,10"/>

                <xctk:ColorPicker x:Name="CategoryColorPicker"
                                  Margin="10,10,10,0"
                                  Height="35"
                                  Width="200"
                                  SelectedColor="#3E5C4C"
                                  Background="#151A17"
                                  BorderBrush="#2F3A33"
                                  Foreground="White"/>
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Width="80" Style="{StaticResource CancelButton}" Click="Cancel_Click"/>
                <Button Content="Добавить" Width="80" Style="{StaticResource MainButton}" Click="Add_Click" Background="#3E5C4C"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
