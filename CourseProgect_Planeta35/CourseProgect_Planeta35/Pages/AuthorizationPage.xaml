<Page x:Class="CourseProgect_Planeta35.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="480" d:DesignWidth="400"
      Title="AuthorizationPage">

    <Page.Resources>

        <!-- TAB STYLE -->
        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="#A8B3A8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2F3A33"
                                BorderThickness="1"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#8B9B4C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DropShadowEffect x:Key="ShadowEffect"
                           BlurRadius="25"
                           ShadowDepth="0"
                           Opacity="0.25"/>
    </Page.Resources>

    <!-- 🌿 BACKGROUND -->
    <Grid RenderOptions.BitmapScalingMode="HighQuality"
          RenderOptions.EdgeMode="Unspecified">

        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Brush1"                     
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.5"
                                     RadiusY="0.5"
                                     MappingMode="RelativeToBoundingBox">
                    <GradientStop Color="#151A17" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.75">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Brush2"                     
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.5"
                                     RadiusY="0.5"
                                     MappingMode="RelativeToBoundingBox">
                    <GradientStop Color="#3E5C4C" Offset="0"/>
                    <GradientStop Color="#1C2621" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.35">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Brush3"                     
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.5"
                                     RadiusY="0.5"
                                     MappingMode="RelativeToBoundingBox">
                    <GradientStop Color="#8B9B4C" Offset="0"/>
                    <GradientStop Color="#1A1F1C" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- CONTENT -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320">

            <!-- HEADER -->
            <StackPanel HorizontalAlignment="Center" Margin="0 0 0 18">

                <Border Width="70"
                        Height="70"
                        CornerRadius="18"
                        Background="#1C1F1D"
                        Effect="{StaticResource ShadowEffect}">
                    <TextBlock Text="📦"
                               FontSize="34"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Система учёта имущества"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 10 0 0"/>

                <TextBlock Text="управление инвентарём"
                           Foreground="#A8B3A8"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- GLASS CARD -->
            <Border Background="#CC1E2320"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#2F3A33"
                    BorderThickness="1"
                    Effect="{StaticResource ShadowEffect}">

                <StackPanel>

                    <!-- TABS -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0 0 0 15">

                        <ToggleButton x:Name="LoginTab"
                                      Content="Вход"
                                      Width="120"
                                      Margin="0 0 10 0"
                                      Style="{StaticResource TabButtonStyle}"
                                      Checked="LoginTab_Checked"/>

                        <ToggleButton x:Name="RegisterTab"
                                      Content="Регистрация"
                                      Width="120"
                                      Style="{StaticResource TabButtonStyle}"
                                      Checked="RegisterTab_Checked"/>
                    </StackPanel>

                    <!-- NAME -->
                    <StackPanel x:Name="RegisterNameField"
                                Visibility="Collapsed"
                                Margin="0 0 0 10">

                        <TextBlock Text="Имя" Foreground="#C9D1C9"/>
                        <TextBox x:Name="NameBox"
                                 Height="30"
                                 Margin="0 5 0 10"
                                 Background="#151A17"
                                 Foreground="White"
                                 BorderBrush="#2F3A33"/>
                    </StackPanel>

                    <!-- EMAIL -->
                    <TextBlock Text="Email" Foreground="#C9D1C9"/>
                    <TextBox x:Name="EmailBox"
                             Height="30"
                             Margin="0 5 0 10"
                             Background="#151A17"
                             Foreground="White"
                             BorderBrush="#2F3A33"/>

                    <!-- PASSWORD -->
                    <TextBlock Text="Пароль" Foreground="#C9D1C9"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="30"
                                 Margin="0 5 0 12"
                                 Background="#151A17"
                                 Foreground="White"
                                 BorderBrush="#2F3A33"/>

                    <!-- ERROR -->
                    <TextBlock x:Name="ErrorText"
                               Foreground="#FF6B6B"
                               Margin="0 0 0 10"
                               Visibility="Collapsed"
                               TextAlignment="Center"/>

                    <!-- BUTTONS -->
                    <ToggleButton Content="Продолжить"
                                  Background="#8B9B4C"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  Click="Submit_Click"
                                  Height="34"
                                  Margin="0 0 0 8"/>

                    <ToggleButton Content="Вход как гость"
                                  Background="Transparent"
                                  Foreground="#A8B3A8"
                                  BorderBrush="#2F3A33"
                                  BorderThickness="1"
                                  Cursor="Hand"
                                  Click="GuestLogin_Click"
                                  Height="30"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>