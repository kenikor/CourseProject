<Page x:Class="CourseProgect_Planeta35.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="480" d:DesignWidth="400"
      Title="AuthorizationPage">

    <Page.Resources>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TAB STYLE -->
        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2F3A33"
                                BorderThickness="1"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3E5C4C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Border CornerRadius="999"
            ClipToBounds="True">
        <!-- 🌿 BACKGROUND -->
        <Grid RenderOptions.BitmapScalingMode="HighQuality"
          RenderOptions.EdgeMode="Unspecified">

            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="Brush1"                     
                                         Center="0.5,0.5"
                                         GradientOrigin="0.5,0.5"
                                         RadiusX="0.5"
                                         RadiusY="0.5"
                                         MappingMode="RelativeToBoundingBox">
                        <GradientStop Color="#151A17" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </RadialGradientBrush>               </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.75">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="Brush2"                     
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.5"
                                     RadiusY="0.5"
                                     MappingMode="RelativeToBoundingBox">
                        <GradientStop Color="#3E5C4C" Offset="0"/>
                        <GradientStop Color="#1C2621" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.35">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="Brush3"                     
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.5"
                                     RadiusY="0.5"
                                     MappingMode="RelativeToBoundingBox">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- CONTENT -->
            <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320">

                <!-- HEADER -->
                <StackPanel HorizontalAlignment="Center" Margin="0 0 0 18">

                    <Border Width="70"
                        Height="70"
                        CornerRadius="18"
                        Background="#3E5C4C">
                        <TextBlock Text="📦"
                               FontSize="34"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Система учёта имущества"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 10 0 0"/>

                    <TextBlock Text="управление инвентарём"
                           Foreground="White"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Background="#CC1E2320"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#2F3A33"
                    BorderThickness="1">

                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0 0 0 15">

                            <ToggleButton x:Name="LoginTab"
                                      Content="Вход"
                                      Width="120"
                                      Margin="0 0 10 0"
                                      Style="{StaticResource TabButtonStyle}"
                                      Checked="LoginTab_Checked"/>

                            <ToggleButton x:Name="RegisterTab"
                                      Content="Регистрация"
                                      Width="120"
                                      Style="{StaticResource TabButtonStyle}"
                                      Checked="RegisterTab_Checked"/>
                        </StackPanel>

                        <StackPanel x:Name="RegisterNameField"
                                Visibility="Collapsed"
                                Margin="0 0 0 10">

                            <TextBlock Text="Имя" Foreground="#C9D1C9"/>
                            <TextBox x:Name="NameBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="30"
                                 Margin="0 5 0 10"
                                 Background="#151A17"
                                 Foreground="White"
                                 BorderBrush="#2F3A33"/>
                        </StackPanel>

                        <TextBlock Text="Email" Foreground="White"/>
                        <TextBox x:Name="EmailBox"
                             Height="30"
                             Margin="0 5 0 10"
                             Background="#151A17"
                             Style="{StaticResource ModernTextBox}"
                             Foreground="White"
                             BorderBrush="#2F3A33"/>

                        <TextBlock Text="Пароль" Foreground="White"/>
                        <PasswordBox x:Name="PasswordBox"
                                 Height="30"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0 5 0 12"
                                 Background="#151A17"
                                 Foreground="White"
                                 BorderBrush="#2F3A33"/>

                        <TextBlock x:Name="ErrorText"
                               Foreground="Red"
                               Margin="0 0 0 10"
                               Visibility="Collapsed"
                               TextAlignment="Center"/>

                        <ToggleButton Content="Продолжить"
                                  Background="#3E5C4C"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  Click="Submit_Click"
                                  Style="{StaticResource TabButtonStyle}"
                                  Height="34"
                                  Margin="0 0 0 8"/>

                        <ToggleButton Content="Вход как гость"
                                  Background="Transparent"
                                  Foreground="White"
                                  BorderBrush="#3E5C4C"
                                  BorderThickness="1"
                                  Cursor="Hand"
                                  Click="GuestLogin_Click"
                                  Style="{StaticResource TabButtonStyle}"
                                  Height="30"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Page>