<Window x:Class="CourseProgect_Planeta35.Pages.AssetCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка объекта"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="480" Height="650"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Общий стиль TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24352C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5C4C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки отмены -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="Foreground" Value="#3C2F1F"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#2B3A31" Padding="20" Margin="10">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Проверка объекта"
                       HorizontalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0 0 0 10"/>

            <Border Height="180" Background="#F0F0F0" CornerRadius="10" Margin="0 10 0 10">
                <Image x:Name="AssetImage" Stretch="UniformToFill" Margin="4"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0 5">
                <TextBlock Text="Категория: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="CategoryText"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 5">
                <TextBlock Text="Серийный номер: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="SerialText"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 5">
                <TextBlock Text="Ответственный: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="ResponsibleText"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <TextBlock Text="Статус: " FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="StatusText"/>
            </StackPanel>

            <!-- Кнопка проверки объекта -->
            <Button x:Name="BtnMarkChecked"
                    Content="Объект проверен"
                    Style="{StaticResource MainButton}"
                    Margin="0 10 0 10"
                    FontSize="15"
                    Width="400"
                    Height="36"
                    Background="#3E5C4C"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="BtnMarkChecked_Click"/>


            <TextBlock Text="Заметки:" FontWeight="Bold" Margin="0 10 0 5" Foreground="White"/>
            <TextBox x:Name="NotesBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

            <!-- Кнопка сохранить -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Сохранить" Width="100" Style="{StaticResource MainButton}" Click="Save_Click" Background="#3E5C4C"/>
                <Button Content="Отмена" Width="100" Style="{StaticResource CancelButton}" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
