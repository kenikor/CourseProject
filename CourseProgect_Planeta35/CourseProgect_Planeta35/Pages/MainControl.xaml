<UserControl x:Class="CourseProgect_Planeta35.MainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- 🌿 GLASS CARD -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="8"/>

            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CC1E2320"/>
                        <GradientStop Color="#991A1F1C" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>

            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25"
                                      ShadowDepth="3"
                                      Opacity="0.3"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                 To="1.04" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>

                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                 To="1.0" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                 To="1.0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>

                    <Setter Property="BorderBrush" Value="#8B9B4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 🔘 BUTTON -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E2320"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#8B9B4C"/>
                                <Setter TargetName="bg" Property="Background" Value="#243028"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- 🌑 BACKGROUND -->
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.25">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.3,0.3"
                                         GradientOrigin="0.2,0.2"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#3E5C4C"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.15">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.8,0.2"
                                         GradientOrigin="0.9,0.1"
                                         RadiusX="0.8"
                                         RadiusY="0.8">
                        <GradientStop Color="#8B9B4C"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 📊 CONTENT -->
        <ScrollViewer>
            <StackPanel Margin="22">

                <!-- 🧠 HEADER -->
                <TextBlock FontSize="14"
                           Foreground="#C9D1C9"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="12"
                          ShadowDepth="0"
                          Color="#8B9B4C"
                          Opacity="0.35"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- 🚀 HERO -->
                <Border CornerRadius="20"
                        Padding="18"
                        Margin="0,0,0,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2A3B33"/>
                            <GradientStop Color="#141A17" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40"
                                          ShadowDepth="5"
                                          Opacity="0.35"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Система активна"
                                       Foreground="#A7B7A7"/>

                            <TextBlock Text="Мониторинг и управление объектами"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,6,0,8"/>

                            <TextBlock Text="Последняя синхронизация: сейчас"
                                       Foreground="#7F8F7F"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                CornerRadius="14"
                                Background="#1E2320"
                                BorderBrush="#8B9B4C"
                                BorderThickness="1"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="📊 Статус"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Все системы OK"
                                           Foreground="#8B9B4C"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 📈 LIVE CHART (Stripe-style) -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,18">
                    <StackPanel>

                        <TextBlock Text="Динамика системы"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Обновляется в реальном времени"
                                   FontSize="12"
                                   Foreground="#8B9B4C"
                                   Margin="0,2,0,10"/>

                        <lvc:CartesianChart 
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            Height="220"
                            Background="#1E2320"
                            LegendPosition="Top"
                            LegendTextPaint="{Binding LegendPaint}"/>

                    </StackPanel>
                </Border>

                <!-- 📊 STATS -->
                <UniformGrid Columns="4" Margin="0,0,0,18">

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Всего объектов" Foreground="#C9D1C9"/>
                            <TextBlock x:Name="TotalObjectsText"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="↑ активность"
                                       Foreground="#8B9B4C"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="В эксплуатации" Foreground="#C9D1C9"/>
                            <TextBlock x:Name="ActiveObjectsText"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#8B9B4C"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Обслуживание" Foreground="#C9D1C9"/>
                            <TextBlock x:Name="MaintenanceObjectsText"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#8B9B4C"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Стоимость" Foreground="#C9D1C9"/>
                            <TextBlock x:Name="TotalValueText"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#8B9B4C"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- 📂 CATEGORIES -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,18">
                    <StackPanel>

                        <!-- HEADER -->
                        <TextBlock Text="Категории"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#E6EFE6"
                                   Margin="0,0,0,12"/>

                        <!-- subtle divider -->
                        <Rectangle Height="1"
                                   Margin="0,0,0,12"
                                   Opacity="0.4">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B9B4C" Offset="0"/>
                                    <GradientStop Color="#2F3A33" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- CONTENT -->
                        <StackPanel x:Name="CategoriesPanel"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>