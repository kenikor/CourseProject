<!-- MainPage.xaml -->
<Page x:Class="CourseProgect_Planeta35.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:CourseProgect_Planeta35.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage" Cursor="">

    <Page.Resources>
        <Style TargetType="ToggleButton" x:Key="MenuButtonStyle">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="10">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Active -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#8B9B4C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>

        <!-- 🌑 ФОН -->
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.25">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="BgBrush1"
                                     Center="0.3,0.3"
                                     GradientOrigin="0.2,0.2"
                                     RadiusX="0.9"
                                     RadiusY="0.9">
                        <GradientStop Color="#3E5C4C"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.15">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="BgBrush2"
                                     Center="0.8,0.2"
                                     GradientOrigin="0.9,0.1"
                                     RadiusX="0.8"
                                     RadiusY="0.8">
                        <GradientStop Color="#8B9B4C"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 🧊 ОСНОВНОЙ UI -->
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0"
                    Margin="10"
                    CornerRadius="16"
                    Background="#1A1F1C"
                    BorderBrush="#2B3A31"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <StackPanel Margin="15" Orientation="Horizontal">
                        <Border Width="40" Height="40"
                            Background="#3E5C4C"
                            CornerRadius="10">
                            <TextBlock Text="📦"
                                   FontSize="22"
                                   Foreground="AliceBlue"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Учёт имущества"
                                   Foreground="White"
                                   FontSize="16"/>
                            <TextBlock Text="v1.0"
                                   Foreground="White"
                                   FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- MENU -->
                    <StackPanel Grid.Row="1">

                        <ToggleButton x:Name="BtnDashboard" Content="Главная" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                        <ToggleButton x:Name="BtnInventory" Content="Инвентарь" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                        <ToggleButton x:Name="BtnCheck" Content="Инвентаризация" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                        <ToggleButton x:Name="BtnReports" Content="Отчёты" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>

                        <StackPanel x:Name="AdminPanel" Margin="0,20,0,0" Visibility="Collapsed">
                            <TextBlock Text="Администрирование"
                                   Foreground="#C5C895"
                                   FontSize="12"
                                   Margin="10"/>

                            <ToggleButton x:Name="BtnCategories" Content="Категории" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                            <ToggleButton x:Name="BtnDepartments" Content="Подразделения" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                            <ToggleButton x:Name="BtnUsers" Content="Пользователи" Style="{StaticResource MenuButtonStyle}" Checked="MenuButton_Checked"/>
                            <ToggleButton x:Name="BtnProcurement"
                                          Content="Закупки"
                                          Style="{StaticResource MenuButtonStyle}"
                                          Checked="MenuButton_Checked"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- LOGOUT -->
                    <ToggleButton   Grid.Row="2"
                                    Content="Выйти"
                                    Margin="10"
                                    Height="40"
                                    Background="#2B3A31"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnLogout_Checked"/>

                </Grid>
            </Border>

            <!-- CONTENT -->
            <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Margin="10"
               NavigationUIVisibility="Hidden"/>

        </Grid>

    </Grid>
</Page>
