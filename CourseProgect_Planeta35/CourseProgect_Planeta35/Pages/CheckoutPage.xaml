<UserControl x:Class="CourseProgect_Planeta35.Pages.CheckoutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E9">

    <UserControl.Resources>
        <!-- ТВОЙ стиль кнопок -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#8B9B4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">

            <TextBlock Text="Оформление заказа"
                       FontSize="28"
                       Margin="0,0,0,20"
                       Foreground="#3C2F1F"/>

            <!-- Способ оплаты -->
            <TextBlock Text="Способ оплаты" FontSize="18" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Карта"
            Width="120"
            Height="40"
            FontSize="14"
            Style="{StaticResource MainButton}"
            Click="Card_Click"/>

                <Button Content="Счёт"
            Width="120"
            Height="40"
            FontSize="14"
            Style="{StaticResource MainButton}"
            Click="Invoice_Click"/>

                <Button Content="Наличные"
            Width="120"
            Height="40"
            FontSize="14"
            Style="{StaticResource MainButton}"
            Click="Cash_Click"/>
            </StackPanel>

            <!-- Карта -->
            <StackPanel x:Name="CardPanel" Margin="0,20,0,0">
                <TextBlock Text="Номер карты"/>
                <TextBox x:Name="CardNumber"
                         Margin="0,5"
                         MaxLength="19"
                         PreviewTextInput="CardNumber_PreviewTextInput"
                         TextChanged="CardNumber_TextChanged"/>
                
                <TextBlock Text="Имя держателя"/>
                <TextBox x:Name="CardHolder" Margin="0,5"/>
                
                <TextBlock Text="MM/YY"/>
                <TextBox x:Name="Expiry" Margin="0,5"/>
                
                <TextBlock Text="CVV"/>
                <TextBox x:Name="CVV"
                         Margin="0,5"
                         MaxLength="3"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"
                         DataObject.Pasting="DigitsOnly_Pasting"/>
            </StackPanel>

            <!-- Адрес -->
            <TextBlock Text="Адрес доставки" Margin="0,20,0,5"/>
            <TextBox x:Name="AddressBox" Height="30"/>

            <TextBlock Text="Комментарий" Margin="0,10,0,5"/>
            <TextBox x:Name="NotesBox" Height="60"/>

        </StackPanel>

        <!-- ПРАВАЯ ЧАСТЬ -->
        <Border Grid.Column="1"
                Background="White"
                Padding="15"
                Margin="20,0,0,0"
                CornerRadius="8"
                BorderBrush="#C5C895"
                BorderThickness="1">
            
            <StackPanel Grid.Column="1" Background="White" >

            <TextBlock Text="Итого" FontSize="20" Margin="0,0,0,10"/>

                <ListBox x:Name="SummaryList" BorderThickness="0" Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Item.Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat=Кол-во: {0}}" 
                               FontSize="12"
                               Foreground="Gray"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                           Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}"
                           Foreground="#8B9B4C"
                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="TotalText"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       Margin="0,10"/>

            <Button Content="Оформить заказ"
                    Style="{StaticResource MainButton}"
                    Height="40"
                    Click="Checkout_Click"/>

        </StackPanel>
        </Border>        
    </Grid>
</UserControl>