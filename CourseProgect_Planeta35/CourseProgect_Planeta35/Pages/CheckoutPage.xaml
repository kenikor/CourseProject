<UserControl x:Class="CourseProgect_Planeta35.Pages.CheckoutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#151A17">

    <UserControl.Resources>

        <!-- SHADOW -->
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="25"
                          ShadowDepth="0"
                          Opacity="0.25"/>

        <!-- BUTTON STYLE -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#24352C"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3E5C4C"/>
                                <Setter TargetName="border"
                                        Property="BorderThickness"
                                        Value="0"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX STYLE -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#3E5C4C"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#8B9B4C"/>
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- BACKGROUND -->
    <Grid>

        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.6"
                                     RadiusY="0.6">
                    <GradientStop Color="#151A17" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.7">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.6"
                                     RadiusY="0.6">
                    <GradientStop Color="#3E5C4C" Offset="0"/>
                    <GradientStop Color="#1C2621" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.35">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.6"
                                     RadiusY="0.6">
                    <GradientStop Color="#8B9B4C" Offset="0"/>
                    <GradientStop Color="#1A1F1C" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- MAIN GRID -->
        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0"
                    Background="#CC1E2320"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#2F3A33"
                    BorderThickness="1"
                    Effect="{StaticResource ShadowEffect}">

                <StackPanel>

                    <TextBlock Text="Оформление заказа"
                               FontSize="28"
                               Margin="0,0,0,20"
                               Foreground="White"/>

                    <TextBlock Text="Способ оплаты"
                               FontSize="18"
                               Margin="0,0,0,10"
                               Foreground="White"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                        <Button Content="Карта"
                                Width="120"
                                Height="40"
                                FontSize="14"
                                Style="{StaticResource MainButton}"
                                Click="Card_Click"
                                Background="#3E5C4C"/>

                        <Button Content="Счёт"
                                Width="120"
                                Height="40"
                                FontSize="14"
                                Style="{StaticResource MainButton}"
                                Click="Invoice_Click"
                                Background="#3E5C4C"
                                Margin="10,0,0,0"/>

                        <Button Content="Наличные"
                                Width="120"
                                Height="40"
                                FontSize="14"
                                Style="{StaticResource MainButton}"
                                Click="Cash_Click"
                                Background="#3E5C4C"
                                Margin="10,0,0,0"/>

                    </StackPanel>

                    <!-- CARD -->
                    <StackPanel x:Name="CardPanel" Margin="0,20,0,0">

                        <TextBlock Text="Номер карты" Foreground="White"/>
                        <TextBox x:Name="CardNumber"
                                 Margin="0,5"
                                 MaxLength="19"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="CardNumber_PreviewTextInput"
                                 TextChanged="CardNumber_TextChanged"/>

                        <TextBlock Text="Имя держателя" Foreground="White"/>
                        <TextBox x:Name="CardHolder"
                                 Margin="0,5"
                                 Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="MM/YY" Foreground="White"/>
                        <TextBox x:Name="Expiry"
                                 Margin="0,5"
                                 Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="CVV" Foreground="White"/>
                        <TextBox x:Name="CVV"
                                 Margin="0,5"
                                 MaxLength="3"
                                 Style="{StaticResource ModernTextBox}"
                                 PreviewTextInput="DigitsOnly_PreviewTextInput"
                                 DataObject.Pasting="DigitsOnly_Pasting"/>

                    </StackPanel>

                    <TextBlock Text="Адрес доставки"
                               Margin="0,20,0,5"
                               Foreground="White"/>

                    <TextBox x:Name="AddressBox"
                             Height="30"
                             Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Комментарий"
                               Margin="0,10,0,5"
                               Foreground="White"/>

                    <TextBox x:Name="NotesBox"
                             Height="60"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>
            </Border>

            <!-- RIGHT -->
            <Border Grid.Column="1"
                    Background="#CC1E2320"
                    Padding="15"
                    Margin="20,0,0,0"
                    CornerRadius="18"
                    BorderBrush="#2F3A33"
                    BorderThickness="1"
                    Effect="{StaticResource ShadowEffect}">

                <StackPanel>

                    <TextBlock Text="Итого"
                               FontSize="20"
                               Margin="0,0,0,10"
                               Foreground="White"/>

                    <ListBox x:Name="SummaryList"
                             BorderThickness="0"
                             Background="Transparent"
                             Height="200">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A211D"
                                        CornerRadius="10"
                                        Padding="10"
                                        Margin="0,5">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- LEFT -->
                                        <StackPanel>

                                            <!-- NAME -->
                                            <TextBlock Text="{Binding Item.Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- QUANTITY -->
                                            <TextBlock Text="{Binding Quantity, StringFormat=Количество: {0}}"
                                                       FontSize="12"
                                                       Foreground="#9AA59F"
                                                       Margin="0,2,0,0"/>

                                        </StackPanel>

                                        <!-- PRICE -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}"
                                                   Foreground="#8B9B4C"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>

                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                    <TextBlock x:Name="TotalText"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Margin="0,10"
                               Foreground="White"/>

                    <Button Content="Оформить заказ"
                            Style="{StaticResource MainButton}"
                            Height="40"
                            Click="Checkout_Click"
                            Background="#3E5C4C"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>