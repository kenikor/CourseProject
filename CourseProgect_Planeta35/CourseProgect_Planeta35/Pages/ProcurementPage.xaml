<UserControl x:Class="CourseProgect_Planeta35.Pages.ProcurementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <!-- 🌑 фон -->
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.18">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.2,0.2"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 🧊 UI -->
        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0" x:Name="CartColumn"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <DockPanel Grid.Column="0">

                <!-- HEADER -->
                <Border DockPanel.Dock="Top"
                        Background="#1E2421"
                        Padding="16"
                        CornerRadius="14"
                        BorderBrush="#2F3B33"
                        BorderThickness="1"
                        Margin="0 0 0 14">

                    <Grid>

                        <StackPanel>
                            <TextBlock Text="Закупка"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Выбор товаров и оформление заказа"
                                       Foreground="#BFCBC2"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right"
                                Click="ToggleCart_Click"
                                Background="#8B9B4C"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="12,6"
                                FontWeight="SemiBold">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒 Корзина"/>

                                <Border Background="#2A322D"
                                        CornerRadius="10"
                                        Margin="8 0 0 0"
                                        Padding="6 2"
                                        Visibility="Collapsed"
                                        x:Name="BadgeBorder">

                                    <TextBlock x:Name="CartCountText"
                                               Foreground="White"
                                               FontSize="12"/>
                                </Border>

                            </StackPanel>
                        </Button>

                    </Grid>

                </Border>

                <!-- FILTERS -->
                <Border DockPanel.Dock="Top"
                        Background="#1E2421"
                        Padding="14"
                        CornerRadius="14"
                        BorderBrush="#2F3B33"
                        BorderThickness="1"
                        Margin="0 0 0 14">

                    <WrapPanel>

                        <TextBox x:Name="SearchBox"
                                 Width="300"
                                 Height="34"
                                 Margin="0 0 10 0"
                                 Background="#2A322D"
                                 Foreground="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>

                        <ComboBox x:Name="CategoryFilter"
                                  Width="200"
                                  Background="#2A322D"
                                  Foreground="White"
                                  BorderThickness="0"
                                  SelectionChanged="CategoryFilter_SelectionChanged"/>

                    </WrapPanel>

                </Border>

                <!-- PRODUCTS -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="ItemsList">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <!-- CARD -->
                                <Border Width="240"
                                        Margin="10"
                                        Background="#1E2421"
                                        CornerRadius="14"
                                        BorderBrush="#2F3B33"
                                        BorderThickness="1"
                                        Padding="12">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#8B9B4C"/>
                                                    <Setter Property="Background" Value="#232B26"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>

                                        <!-- IMAGE -->
                                        <Border Height="120"
                                                Background="#2A322D"
                                                CornerRadius="10"
                                                Margin="0 0 0 10">

                                            <TextBlock Text="📦"
                                                       FontSize="36"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8B9B4C"/>
                                        </Border>

                                        <!-- NAME -->
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="#BFCBC2"
                                                   FontSize="12"
                                                   Margin="0 4 0 0"/>

                                        <!-- PRICE -->
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   Margin="0 10 0 0"/>

                                        <!-- BUTTON -->
                                        <Button Content="В корзину"
                                                Background="#8B9B4C"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="6"
                                                FontWeight="SemiBold"
                                                IsEnabled="{Binding InStock}"
                                                Click="AddToCart_Click"
                                                Tag="{Binding Id}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

            </DockPanel>

            <!-- CART -->
            <Border Grid.Column="1"
                    Background="#1E2421"
                    BorderBrush="#2F3B33"
                    BorderThickness="1,0,0,0"
                    Padding="16"
                    CornerRadius="0">

                <DockPanel>

                    <!-- HEADER -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Корзина"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Content="✕"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="ToggleCart_Click"/>
                    </StackPanel>

                    <!-- TOTAL -->
                    <TextBlock x:Name="TotalSumText"
                               DockPanel.Dock="Bottom"
                               Foreground="#8B9B4C"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0 10 0 0"
                               HorizontalAlignment="Right"/>

                    <!-- LIST -->
                    <ListBox x:Name="CartListBox"
                             Background="Transparent"
                             BorderThickness="0">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#2A322D"
                                        CornerRadius="10"
                                        Padding="8"
                                        Margin="0 6">

                                    <StackPanel>

                                        <TextBlock Text="{Binding Item.Name}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock Text="{Binding Quantity, StringFormat={}x{0}}"
                                                       Foreground="#BFCBC2"/>

                                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}"
                                                       Foreground="#8B9B4C"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </DockPanel>

            </Border>

        </Grid>

    </Grid>
</UserControl>