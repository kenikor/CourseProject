<UserControl x:Class="CourseProgect_Planeta35.Pages.ProcurementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#8B9B4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#75863F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F1E9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="CartColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">

            <Border DockPanel.Dock="Top"
                    Background="White"
                    Padding="20"
                    BorderBrush="#C5C895"
                    BorderThickness="0,0,0,1">

                <StackPanel>
                    <Grid Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Закупка принадлежностей"
                                       FontSize="28"
                                       Foreground="#3C2F1F"/>
                            <TextBlock Text="Выберите необходимые товары и оформите заказ"
                                       Foreground="#3C2F1F"
                                       Opacity="0.6"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right"
                                Click="ToggleCart_Click"
                                Padding="15,5"
                                Style="{StaticResource MainButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒 Корзина "
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="BadgeBorder"
                                        Background="#B89968"
                                        CornerRadius="10"
                                        MinWidth="20"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="CartCountText"
                                               Text="0"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="5,0"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                 TextChanged="SearchBox_TextChanged"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Margin="0,0,10,0"/>

                        <ComboBox x:Name="CategoryFilter"
                                  Grid.Column="1"
                                  SelectionChanged="CategoryFilter_SelectionChanged"
                                  Height="35"/>
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    Width="220"
                                    Margin="10"
                                    CornerRadius="8"
                                    BorderBrush="#C5C895"
                                    BorderThickness="1">

                                <StackPanel>
                                    <Border Height="120"
                                            Background="#E8E9D8"
                                            CornerRadius="8,8,0,0">
                                        <TextBlock Text="📦"
                                                   FontSize="40"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.3"/>
                                    </Border>

                                    <Border Padding="20">
                                        <StackPanel>

                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       Height="40"/>

                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="#8B9B4C"/>

                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}"
                                                       FontSize="18"
                                                       Foreground="#3C2F1F"
                                                       Margin="0,10"/>

                                            <Button Content="В корзину"
                                                    Style="{StaticResource MainButton}"
                                                    IsEnabled="{Binding InStock}"
                                                    Click="AddToCart_Click"
                                                    Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#C5C895"
                BorderThickness="1,0,0,0">

            <DockPanel Margin="20">

                <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                    <TextBlock Text="Корзина"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ToggleCart_Click"/>
                </Grid>

                <Button DockPanel.Dock="Bottom"
                        Content="Оформить заказ"
                        Height="45"
                        Click="Checkout_Click"
                        Style="{StaticResource MainButton}"/>

                <TextBlock x:Name="TotalSumText"
                           DockPanel.Dock="Bottom"
                           Text="Итого: 0 ₽"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,10"
                           HorizontalAlignment="Right"/>

                <ListBox x:Name="CartListBox" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="250" Margin="0,5">
                                <StackPanel>
                                    <TextBlock Text="{Binding Item.Name}"
                                               FontWeight="SemiBold"/>
                                    <Grid>
                                        <TextBlock Text="{Binding Quantity, StringFormat={}Кол-во: {0}}"/>
                                        <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#8B9B4C"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>