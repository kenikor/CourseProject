<UserControl x:Class="CourseProgect_Planeta35.Pages.ProcurementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- ТВОЙ стиль кнопок -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#3E5C4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"/>

                            <Grid Margin="10,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected -->
                                <ContentPresenter Grid.Column="0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                                <!-- Arrow -->
                                <ToggleButton Grid.Column="1"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand">

                                    <TextBlock Text="▼"
                                       FontSize="10"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                </ToggleButton>

                            </Grid>

                            <!-- Dropdown -->
                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           PopupAnimation="Fade">

                                <Border Background="#1C2621"
                                BorderBrush="#3E5C4C"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,5,0,0">

                                    <ScrollViewer>

                                        <ItemsPresenter/>

                                    </ScrollViewer>

                                </Border>

                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#3E5C4C"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#8B9B4C"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#1C2621"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ITEMS -->
        <Style TargetType="ComboBoxItem">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBoxItem">

                        <Border x:Name="Bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Margin="4">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#24352C"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#3E5C4C"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>
    
    <Grid>

        <!-- 🌑 фон -->
        <Grid>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1F1C" Offset="0"/>
                        <GradientStop Color="#2B3A31" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Opacity="0.18">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.2,0.2"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#8B9B4C" Offset="0"/>
                        <GradientStop Color="#1A1F1C" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- 🧊 UI -->
        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0" x:Name="CartColumn"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <DockPanel Grid.Column="0">

                <!-- HEADER -->
                <Border DockPanel.Dock="Top"
                        Background="#1E2421"
                        Padding="16"
                        CornerRadius="14"
                        BorderBrush="#2F3B33"
                        BorderThickness="1"
                        Margin="0 0 0 14">

                    <Grid>

                        <StackPanel>
                            <TextBlock Text="Закупка"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Выбор товаров и оформление заказа"
                                       Foreground="#BFCBC2"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right"
                                Click="ToggleCart_Click"
                                Style="{StaticResource MainButton}"
                                Foreground="White"
                                Background="#3E5C4C"
                                BorderThickness="0"     
                                Padding="12,6"
                                FontWeight="SemiBold">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒 Корзина"/>

                                <Border Background="#2A322D"
                                        CornerRadius="10"
                                        Margin="8 0 0 0"
                                        Padding="6 2"
                                        Visibility="Collapsed"
                                        x:Name="BadgeBorder">

                                    <TextBlock x:Name="CartCountText"
                                               Foreground="White"
                                               FontSize="12"/>
                                </Border>

                            </StackPanel>
                        </Button>

                    </Grid>

                </Border>

                <!-- FILTERS -->
                <Border DockPanel.Dock="Top"
                        Background="#1E2421"
                        Padding="14"
                        CornerRadius="14"
                        BorderBrush="#2F3B33"
                        BorderThickness="1"
                        Margin="0 0 0 14">

                    <WrapPanel>

                        <TextBox x:Name="SearchBox"
                                 Width="300"
                                 Height="34"
                                 Margin="10 0 10 0"
                                 Background="#2A322D"
                                 Foreground="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>

                        <ComboBox x:Name="CategoryFilter"
                                  Width="200"
                                  Margin="10 0 10 0"
                                  Background="#2A322D"
                                  Foreground="White"
                                  BorderThickness="0"
                                  SelectionChanged="CategoryFilter_SelectionChanged"/>

                    </WrapPanel>

                </Border>

                <!-- PRODUCTS -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="ItemsList">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <!-- CARD -->
                                <Border Width="240"
                                        Margin="10"
                                        Background="#1E2421"
                                        CornerRadius="14"
                                        BorderBrush="#2F3B33"
                                        BorderThickness="1"
                                        Padding="12">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#8B9B4C"/>
                                                    <Setter Property="Background" Value="#232B26"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>

                                        <!-- IMAGE -->
                                        <Border Height="120"
                                                Background="#2A322D"
                                                CornerRadius="10"
                                                Margin="0 0 0 10">

                                            <TextBlock Text="📦"
                                                       FontSize="36"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8B9B4C"/>
                                        </Border>

                                        <!-- NAME -->
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="#BFCBC2"
                                                   FontSize="12"
                                                   Margin="0 4 0 0"/>

                                        <!-- PRICE -->
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   Margin="0 10 0 0"/>

                                        <!-- BUTTON -->
                                        <Button Content="В корзину"
                                                Style="{StaticResource MainButton}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="6"
                                                FontWeight="SemiBold"
                                                IsEnabled="{Binding InStock}"
                                                Click="AddToCart_Click"
                                                Tag="{Binding Id}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

            </DockPanel>

            <!-- CART -->
            <Border Grid.Column="1"
                    Background="#1E2421"
                    BorderBrush="#2F3B33"
                    BorderThickness="1,0,0,0"
                    Padding="16"
                    CornerRadius="0">

                <DockPanel>

                    <!-- HEADER -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Корзина"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Content="✕"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="ToggleCart_Click"/>
                    </StackPanel>

                    <!-- TOTAL -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="0 10 0 0">

                        <TextBlock x:Name="TotalSumText"
                                   Foreground="#8B9B4C"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>

                        <Button Content="Оформить заказ"
                                Style="{StaticResource MainButton}"
                                Margin="0 10 0 0"
                                Padding="8"
                                FontWeight="SemiBold"
                                Click="Checkout_Click"/>

                    </StackPanel>

                    <!-- LIST -->
                    <ListBox x:Name="CartListBox"
         Background="Transparent"
         BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A322D"
                    CornerRadius="10"
                    Padding="12,8"
                    Margin="0,4"
                    Width="240">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Item.Name}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   MaxWidth="180"
                                   HorizontalAlignment="Left"/>

                                            <Button Content="✕" 
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                Foreground="#FF6B6B"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="RemoveFromCart_Click"
                                Tag="{Binding Item.Id}"/>
                                        </Grid>

                                        <Grid>
                                            <TextBlock Text="{Binding Quantity, StringFormat={}x{0}}"
                                   Foreground="#BFCBC2"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>

                                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}"
                                   Foreground="#8B9B4C"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>

            </Border>

        </Grid>

    </Grid>
</UserControl>