<UserControl x:Class="CourseProgect_Planeta35.Pages.DepartmentsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#151A17">

    <UserControl.Resources>

        <!-- BUTTON -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#151A17"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2F3A33"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                         CornerRadius="10"
                         Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24352C"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5C4C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- CARD -->
        <Style x:Key="DepartmentCardStyle" TargetType="Border">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="150"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Background" Value="#1E2320"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#2F3B33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.25"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E5C4C"/>
                    <Setter Property="BorderBrush" Value="#8B9B4C"/>
                </Trigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- BACKGROUND -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#151A17" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.15">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.3"
                                     RadiusX="0.8"
                                     RadiusY="0.8">
                    <GradientStop Color="#8B9B4C" Offset="0"/>
                    <GradientStop Color="#000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- CONTENT -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Background="#1E2320"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#2F3A33"
                    BorderThickness="1"
                    Margin="0 0 0 20">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TEXT -->
                    <StackPanel>
                        <TextBlock Text="Подразделения"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock x:Name="CountText"
                                   Margin="0 4 0 0"
                                   Foreground="#BFCBC2"/>
                    </StackPanel>

                    <!-- BUTTON -->
                    <Button Grid.Column="1"
                            Width="200"
                            Height="40"
                            Click="AddDepartment_Click"
                            Background="#3E5C4C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Style="{StaticResource MainButton}"
                            Cursor="Hand">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="＋"
                                       FontSize="18"
                                       Margin="0 -3 6 0"/>
                            <TextBlock Text="Добавить"/>
                        </StackPanel>

                    </Button>

                </Grid>

            </Border>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="DepartmentsList">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border Style="{StaticResource DepartmentCardStyle}">

                                <Grid>

                                    <!-- COLOR STRIPE -->
                                    <Border Width="8"
                                            HorizontalAlignment="Left"
                                            CornerRadius="20 0 0 20"
                                            Background="{Binding Color}"/>

                                    <Grid Margin="22 18 18 18">

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- HEADER -->
                                        <StackPanel Orientation="Horizontal">

                                            <Ellipse Width="14"
                                                     Height="14"
                                                     Fill="{Binding Color}"
                                                     VerticalAlignment="Center"/>

                                            <TextBlock Text="{Binding Name}"
                                                       Margin="10 0 0 0"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>

                                        </StackPanel>

                                        <!-- DESCRIPTION -->
                                        <TextBlock Grid.Row="1"
                                                   Margin="0 14 0 0"
                                                   Text="{Binding Description}"
                                                   Foreground="#C7D2CB"
                                                   TextWrapping="Wrap"
                                                   FontSize="13"/>

                                        <!-- FOOTER -->
                                        <Border Grid.Row="2"
                                                Background="#273029"
                                                CornerRadius="10"
                                                Padding="8 5"
                                                HorizontalAlignment="Left">

                                            <TextBlock Text="Активно"
                                                       Foreground="{Binding Color}"
                                                       FontWeight="SemiBold"
                                                       Margin="0 5 0 0" 
                                                       FontSize="12"/>

                                        </Border>

                                    </Grid>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Grid>

    </Grid>

</UserControl>