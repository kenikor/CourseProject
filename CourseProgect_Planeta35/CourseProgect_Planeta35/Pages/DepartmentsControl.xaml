<!-- DepartmentsControl.xaml -->
<UserControl x:Class="CourseProgect_Planeta35.Pages.DepartmentsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E9">

    <UserControl.Resources>
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="BorderBrush" Value="#D2D5C4"/>
            <Setter Property="Background" Value="#8B9B4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- 🌑 БАЗОВЫЙ ГРАДИЕНТ -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A1F1C" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 💡 мягкое пятно -->
        <Rectangle Opacity="0.25">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.3,0.3"
                                     GradientOrigin="0.2,0.2"
                                     RadiusX="0.9"
                                     RadiusY="0.9">
                    <GradientStop Color="#3E5C4C" Offset="0"/>
                    <GradientStop Color="#1A1F1C" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 🟢 оливковый акцент -->
        <Rectangle Opacity="0.15">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.8,0.2"
                                     GradientOrigin="0.9,0.1"
                                     RadiusX="0.8"
                                     RadiusY="0.8">
                    <GradientStop Color="#8B9B4C" Offset="0"/>
                    <GradientStop Color="#2B3A31" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 🧊 твой UI -->
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel Margin="0 0 0 20">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Подразделения"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="CountText"
                               Margin="0 4 0 0"
                               Foreground="#CFCFCF"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="220"
                        Height="42"
                        Click="AddDepartment_Click"
                        Style="{StaticResource MainButton}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="18" Margin="0 -6 8 0"/>
                        <TextBlock Text="Добавить подразделение"/>
                    </StackPanel>
                </Button>
            </DockPanel>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="DepartmentsPanel"
                           Orientation="Horizontal"/>
            </ScrollViewer>

        </Grid>

    </Grid>
</UserControl>
